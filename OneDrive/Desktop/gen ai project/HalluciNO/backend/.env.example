# Environment Configuration Template
# Copy to .env and fill in your values

# Server Configuration
DEBUG=False
HOST=0.0.0.0
PORT=8000
PYTHONUNBUFFERED=1

# CORS Configuration
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,https://your-frontend-url.vercel.app

# Database (optional - for production)
DATABASE_URL=sqlite:///./halluci_no.db

# Gemini API (optional - for dynamic question generation)
GEMINI_API_KEY=your_gemini_api_key_here
ENABLE_GEMINI=False

# Frontend API URL
API_URL=http://localhost:8000/api
